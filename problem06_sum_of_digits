#include <iostream>
#include <string>
using namespace std;
int ReadPositivNumber(string message)
{
	int number = 0; 
	do
	{
		cout << message << endl;
		cin >> number;
	} while (number <= 0);
	return  number;
}
int  SumOfDigits(int number)
{
	int sum = 0;
	 int Remainder = 0;
	 while (number > 0)
	 {
		 Remainder = number % 10;
			number = number / 10;
			sum += Remainder;
		
	 };
	return sum ;
}
int main()
{
cout<<"\nReverse is:\n"<<
SumOfDigits(ReadPositivNumber("please enter a positive number"))
	<<"\n";
	return  0;
}
