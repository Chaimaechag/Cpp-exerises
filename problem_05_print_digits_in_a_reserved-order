#include <iostream>
#include <string>
using namespace std;
int ReadPositivNumber(string message)
{
	int number = 0; 
	do
	{
		cout << message << endl;
		cin >> number;
	} while (number <= 0);
	return  number;
}
void PrintDigits(int number)
{
	 int Remainder = 0;
	 while (number > 0)
	 {
		 Remainder = number % 10;
		 number = number / 10;
		 cout << Remainder << endl;
	 };
	
}
int main()
{
	PrintDigits(ReadPositivNumber("please enter a positive number"));
	return  0;
}
